<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:WaterOps.Resources.Controls.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="WaterOps.Resources.Controls.Views.SaveChangesView"
             x:DataType="{x:Type local:SaveChangesViewModel}">
    
    <Grid
        ColumnDefinitions="*, Auto"
        RowDefinitions="Auto, *, Auto"
        Margin="4">

        <StackPanel
            Orientation="Horizontal"
            Grid.Column="0"
            Grid.Row="0"
            Spacing="8"
            HorizontalAlignment="Left">
            <Image 
                Source="{SvgImage avares://WaterOps.Resources/Resources/Assets/Icon.svg}"
                Height="24"
                Width="24"/>
            
            <TextBlock
                VerticalAlignment="Center"
                Text="Save Changes?"/>
        </StackPanel>
        
        <StackPanel
            Orientation="Horizontal"
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Right">
            
            <Button
                x:Name="CloseButton"
                Click="CloseButton_OnClick"
                BorderThickness="0">
                
                <PathIcon
                    Data="{DynamicResource Close}"
                    Width="10"
                    Height="10"/>
            </Button>
            
        </StackPanel>
        
        <TextBlock
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="1"
            TextWrapping="Wrap"
            Margin="8"
            VerticalAlignment="Center">
            Changes have been made to the current file. Do you want to save your changes before closing?
        </TextBlock>
        
        <StackPanel
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="8"
            Margin="8"
            HorizontalAlignment="Center">
            
            <StackPanel.Styles>
                <Style Selector="Button">
                    <Setter Property="Width" Value="80"></Setter>
                </Style>
            </StackPanel.Styles>
            
            <Button
                Classes="theme-solid accent"
                Content="Yes"
                Command="{Binding ExecuteYesCommand}"/>
                
            <Button
                Classes="theme-solid danger"
                Content="No"
                Command="{Binding ExecuteNoCommand}"/>
            
            <Button
                Classes="theme-outline"
                Content="Cancel"
                Command="{Binding ExecuteCancelCommand}"/>
            
        </StackPanel>
        
    </Grid>
    
</UserControl>
